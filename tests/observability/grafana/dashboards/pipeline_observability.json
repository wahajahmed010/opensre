{
  "dashboard": {
    "title": "Pipeline Observability",
    "tags": ["pipeline", "observability", "traces", "logs", "metrics"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Pipeline Runs Total",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(pipeline_runs_total)",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 100, "color": "yellow"},
                {"value": 1000, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Pipeline Runs by Status",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 9, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "sum by (status) (pipeline_runs_total)",
            "refId": "A",
            "legendFormat": "{{status}}",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ]
      },
      {
        "id": 3,
        "title": "Pipeline Runs by Execution Run ID",
        "type": "table",
        "gridPos": {"h": 8, "w": 9, "x": 15, "y": 0},
        "targets": [
          {
            "expr": "pipeline_runs_total",
            "refId": "A",
            "format": "table",
            "instant": true,
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "execution_run_id": "Execution Run ID",
                "pipeline_name": "Pipeline Name",
                "status": "Status",
                "Value": "Count"
              }
            }
          }
        ]
      },
      {
        "id": 4,
        "title": "Pipeline Logs by Execution Run ID",
        "type": "logs",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "{service_name=~\"prefect-etl-pipeline|airflow-etl-pipeline|flink-etl-pipeline|lambda-api-ingester|lambda-mock-dag\"}",
            "refId": "A",
            "datasource": {"type": "loki", "uid": "loki"}
          }
        ],
        "options": {
          "dedupStrategy": "none",
          "enableLogDetails": true,
          "prettifyLogMessage": false,
          "showCommonLabels": false,
          "showLabels": false,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": false
        }
      },
      {
        "id": 5,
        "title": "Pipeline Logs Filtered by Execution Run ID",
        "type": "logs",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "{service_name=~\"prefect-etl-pipeline|airflow-etl-pipeline|flink-etl-pipeline|lambda-api-ingester|lambda-mock-dag\"} |= \"execution_run_id\"",
            "refId": "A",
            "datasource": {"type": "loki", "uid": "loki"}
          }
        ],
        "options": {
          "dedupStrategy": "none",
          "enableLogDetails": true,
          "prettifyLogMessage": false,
          "showCommonLabels": false,
          "showLabels": false,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": false
        }
      },
      {
        "id": 6,
        "title": "Pipeline Traces",
        "type": "traces",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 18},
        "targets": [
          {
            "query": "{service_name=~\"prefect-etl-pipeline|airflow-etl-pipeline|flink-etl-pipeline|lambda-api-ingester|lambda-mock-dag\"}",
            "refId": "A",
            "datasource": {"type": "tempo", "uid": "tempo"}
          }
        ],
        "options": {
          "dedupeBy": "traceID",
          "query": "{service_name=~\"prefect-etl-pipeline|airflow-etl-pipeline|flink-etl-pipeline|lambda-api-ingester|lambda-mock-dag\"}"
        }
      },
      {
        "id": 7,
        "title": "Pipeline Duration",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(duration_seconds_bucket[5m])) by (le, pipeline_name))",
            "refId": "A",
            "legendFormat": "p95 - {{pipeline_name}}",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(duration_seconds_bucket[5m])) by (le, pipeline_name))",
            "refId": "B",
            "legendFormat": "p50 - {{pipeline_name}}",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "axisLabel": "Duration (seconds)",
              "axisPlacement": "auto",
              "barAlignment": 0,
              "drawStyle": "line",
              "fillOpacity": 10,
              "gradientMode": "none",
              "hideFrom": {"tooltip": false, "viz": false, "legend": false},
              "lineInterpolation": "linear",
              "lineWidth": 1,
              "pointSize": 5,
              "scaleDistribution": {"type": "linear"},
              "showPoints": "never",
              "spanNulls": false
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Records Processed",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "targets": [
          {
            "expr": "sum(rate(records_processed_total[5m])) by (pipeline_name)",
            "refId": "A",
            "legendFormat": "{{pipeline_name}}",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "axisLabel": "Records/sec",
              "axisPlacement": "auto"
            }
          }
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "execution_run_id",
          "type": "textbox",
          "label": "Execution Run ID",
          "current": {
            "value": "",
            "text": ""
          },
          "options": []
        },
        {
          "name": "pipeline_name",
          "type": "query",
          "label": "Pipeline",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "current": {
            "value": ["All"],
            "text": "All"
          },
          "options": [
            {"value": "All", "text": "All", "selected": true},
            {"value": "prefect-etl-pipeline", "text": "Prefect", "selected": false},
            {"value": "airflow-etl-pipeline", "text": "Airflow", "selected": false},
            {"value": "flink-etl-pipeline", "text": "Flink", "selected": false},
            {"value": "lambda-api-ingester", "text": "Lambda API", "selected": false},
            {"value": "lambda-mock-dag", "text": "Lambda Mock DAG", "selected": false}
          ],
          "query": "label_values(pipeline_runs_total, pipeline_name)"
        }
      ]
    },
    "annotations": {
      "list": []
    }
  }
}
